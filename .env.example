# Kopiere diese Datei nach .env.local und trage deine Werte ein.

# --- LLM (Pflicht) ---
# Google Gemini API Key (Free-Tier): https://aistudio.google.com/apikey
GEMINI_API_KEY=

# --- Login (optional) ---
# Passwort fürs Login-Gate. LEER lassen = offener Demo-Modus (kein Login).
APP_PASSWORD=
# Zufalls-Token fürs Auth-Cookie (nur nötig, wenn APP_PASSWORD gesetzt ist):
#   node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
AUTH_TOKEN=
